{
  "_note": "LE MÉRIDIAN — a living Paris hotel as a PURE-DATA world (no host code; runs on owos_author::build + step). The player's rise (janitor→chef) and the minute-to-minute chopping is the GAME's job; THIS is the brain that makes the hotel actually alive around that loop. A brigade of cooks preps and works service, drawing down the PANTRY commons (draining rollup → the day's covers), restocked by deliveries. Cooks MENTOR apprentices (skill rises — this is you climbing) and feud over the pass (rivalry lowers standing). Station skill+morale rolls up to KITCHEN quality; a rough night broadcasts morale hits down; kitchen quality rolls up to the HOTEL's year-long REPUTATION. Guests arrive in the dining room, some make a REQUEST (a side-task the game would hand the player), and tip when the food's good. A year emerges — good runs, burnout, a rival's sabotage, a reputation climbing toward the gala — all from data.",

  "rng_seed": 3,

  "seed": [
    {
      "kind": "hotel",
      "name": "Le Méridian",
      "reveal": true,
      "stats": { "reputation": 0.35, "wealth": 0.0, "day": 0.0, "covers": 0.0, "review": 0.0 }
    }
  ],

  "generators": [
    { "on": "hotel", "spawn": "kitchen", "count": "1", "cascade": true,
      "child_stats": { "pantry": "0.8", "quality": "0.4", "strain": "0.0", "draw": "0.0", "morale_hit": "0.0" } },
    { "on": "hotel", "spawn": "dining", "count": "1", "cascade": true,
      "child_stats": { "ambience": "0.6", "seats": "12", "tips": "0.0" } },

    { "on": "kitchen", "spawn": "cook", "count": "6",
      "child_stats": {
        "skill":   "0.15 + 0.5*rand(1)",
        "morale":  "0.55 + 0.3*rand(2)",
        "ambition":"0.2 + 0.7*rand(3)",
        "warmth":  "0.2 + 0.7*rand(4)",
        "ration":  "0.8",
        "took":    "0.0",
        "plated":  "0.0",
        "age":     "0.1 + 0.4*rand(5)",
        "alive":   "1"
      }
    },
    { "on": "dining", "spawn": "guest", "count": "4",
      "child_stats": { "patience": "0.4 + 0.4*rand(1)", "spend": "0.3 + 0.5*rand(2)", "asked": "0.0", "happy": "0.5", "here": "1" } }
  ],

  "broadcasts": [
    { "parent_stat": "morale_hit", "child_stat": "morale_hit", "gain": 1.0 },
    { "parent_stat": "reputation", "child_stat": "house_rep", "gain": 1.0 }
  ],

  "rollups": [
    { "parent": "kitchen", "child_stat": "took",   "parent_stat": "draw",    "reduce": "sum",  "drain": true },
    { "parent": "kitchen", "child_stat": "plated", "parent_stat": "service", "reduce": "sum",  "drain": true },
    { "parent": "kitchen", "child_stat": "skill",  "parent_stat": "quality", "reduce": "mean" },
    { "parent": "kitchen", "child_stat": "morale", "parent_stat": "spirit",  "reduce": "mean" },
    { "parent": "dining",  "child_stat": "happy",  "parent_stat": "guestjoy","reduce": "mean" },
    { "parent": "dining",  "child_stat": "here",   "parent_stat": "covers",  "reduce": "sum" },
    { "parent": "hotel",   "child_stat": "quality","parent_stat": "kitchen_q","reduce": "max" },
    { "parent": "hotel",   "child_stat": "guestjoy","parent_stat": "review",  "reduce": "max" }
  ],

  "rules": [
    { "on": "hotel",   "set": "day",        "expr": "day + 1" },
    { "on": "hotel",   "set": "reputation", "expr": "clamp(reputation + 0.02*(kitchen_q - reputation) + 0.02*(review - 0.5), 0, 1)" },
    { "on": "hotel",   "set": "wealth",     "expr": "clamp(wealth + 0.1*review*covers*0.05, 0, 50)" },

    { "on": "kitchen", "set": "pantry",   "expr": "clamp(pantry + 0.12*(1 - pantry) - draw*0.05, 0, 1)" },
    { "on": "kitchen", "set": "strain",   "expr": "clamp(0.15*service + 0.4*(1 - spirit), 0, 1)" },
    { "on": "kitchen", "set": "morale_hit","expr": "0.04*gt(strain,0.6)" },

    { "on": "cook", "set": "age",    "expr": "age + 0.004" },
    { "on": "cook", "set": "morale", "expr": "clamp(morale + 0.01*gt(ration,0.4) - morale_hit - 0.015*lt(ration,0.2), 0, 1)" },
    { "on": "cook", "set": "ration", "expr": "clamp(ration, 0, 1)" }
  ],

  "actions": [
    { "on": "cook", "name": "work_service",
      "score": "gt(ration,0.05)*(0.45 + 0.35*morale)*(0.5+skill)",
      "effects": [
        { "op": "set", "stat": "took",   "expr": "0.1*ration" },
        { "op": "set", "stat": "plated", "expr": "0.3*skill*ration*(0.5+morale)" },
        { "op": "add", "stat": "skill",  "expr": "0.004*(1-skill)" }
      ]
    },

    { "on": "cook", "name": "mentor",
      "score": "warmth*gt(skill,0.45)*gt(morale,0.45)*lt(edge_count(mentee),3)*1.1",
      "effects": [ { "op": "link", "stat": "mentee:cook" } ]
    },

    { "on": "cook", "name": "coach",
      "score": "warmth*gt(edge_count(mentee),0)*gt(morale,0.4)*(0.8 + 0.6*chance(0.5))",
      "effects": [
        { "op": "affect", "stat": "mentee:skill", "expr": "0.03*gt(skill, target.skill)" },
        { "op": "affect", "stat": "mentee:morale", "expr": "0.02" }
      ]
    },

    { "on": "cook", "name": "vie_for_the_pass",
      "score": "ambition*(1-warmth)*gt(skill,0.35)*lt(edge_count(rival),3)*1.0",
      "effects": [ { "op": "link", "stat": "rival:cook" } ]
    },

    { "on": "cook", "name": "undercut_rival",
      "score": "ambition*(1-warmth)*gt(edge_count(rival),0)*(0.7 + 0.6*chance(0.4))",
      "effects": [
        { "op": "affect", "stat": "rival:morale", "expr": "-0.05*ambition*(1 - 0.5*target.warmth)" }
      ]
    },

    { "on": "cook", "name": "take_a_breather",
      "score": "0.35 + 0.7*lt(morale,0.35)",
      "effects": [ { "op": "add", "stat": "morale", "expr": "0.06" } ]
    }
  ],

  "events": [
    { "on": "cook", "when": "gt(skill,0.85)*lt(promoted,0.5)",
      "label": "earns a station — promoted up the brigade",
      "do": [ { "op": "set", "stat": "promoted", "expr": "1" }, { "op": "add", "stat": "morale", "expr": "0.15" } ]
    },
    { "on": "cook", "when": "lt(morale,0.06)*gt(age,0.5)",
      "label": "burns out and walks",
      "do": [ { "op": "set", "stat": "alive", "expr": "0" }, { "op": "unlink", "stat": "mentee" }, { "op": "unlink", "stat": "rival" }, { "op": "despawn" } ]
    },

    { "on": "guest", "when": "gt(patience,0.6)*lt(asked,0.5)*chance(0.3)",
      "label": "a guest asks for something special — a side-task",
      "do": [ { "op": "set", "stat": "asked", "expr": "1" } ]
    },
    { "on": "guest", "when": "gt(house_rep,0.5)*lt(happy,0.9)",
      "label": "a guest leaves delighted — a glowing word",
      "do": [ { "op": "set", "stat": "happy", "expr": "0.95" }, { "op": "add", "stat": "spend", "expr": "0.1" } ]
    },

    { "on": "hotel", "when": "gt(reputation,0.6)*lt(starred,0.5)",
      "label": "★ Le Méridian earns its first star",
      "do": [ { "op": "set", "stat": "starred", "expr": "1" } ]
    },
    { "on": "hotel", "when": "gt(reputation,0.8)*lt(gala,0.5)",
      "label": "★★ the grand ceremony is booked — the gala approaches",
      "do": [ { "op": "set", "stat": "gala", "expr": "1" } ]
    },
    { "on": "kitchen", "when": "lt(pantry,0.12)",
      "label": "the pantry runs bare mid-service",
      "do": [] }
  ]
}
