{
  "_note": "A whole life as LOD-over-TIME. mode=0: coarse YEAR steps — one tick = one year, life-stats drift, life-events fire on thresholds. mode=1: a single day UNFOLDS in human detail — activities gated by time-of-day AND textured by the coarse life-state (a 38-yr-old with two kids and a career has a different Tuesday than a settled 54-yr-old). Life-rules are mode-gated so the day doesn't age you; life-events are STATE-latched so they fire once and never re-fire when you drop into a day.",

  "rules": [
    { "on": "person", "set": "age",         "expr": "age + eq(mode,0)" },
    { "on": "person", "set": "health",      "expr": "clamp(health + eq(mode,0)*(0.005 - 0.0006*max(age-38,0)), 0, 1)" },
    { "on": "person", "set": "career",      "expr": "clamp(career + eq(mode,0)*(0.055*gt(age,21)*lt(age,55) - 0.07*gt(age,63)), 0, 1)" },
    { "on": "person", "set": "wealth",      "expr": "clamp(wealth + eq(mode,0)*(0.025*career - 0.02*gt(age,63) - 0.004), 0, 1)" },
    { "on": "person", "set": "bonds",       "expr": "clamp(bonds + eq(mode,0)*(0.03*lt(age,30) + 0.02*married - 0.012), 0, 1)" },
    { "on": "person", "set": "contentment", "expr": "clamp(contentment + eq(mode,0)*0.2*((0.2 + 0.3*health + 0.25*bonds + 0.25*career) - contentment), 0, 1)" }
  ],

  "events": [
    { "on": "person", "when": "gt(age,21)*eq(has_job,0)", "label": "landed a first job", "do": [ {"op":"set","stat":"has_job","expr":"1"}, {"op":"set","stat":"career","expr":"0.28"}, {"op":"add","stat":"wealth","expr":"0.05"} ] },
    { "on": "person", "when": "gt(age,26)*gt(bonds,0.5)*eq(married,0)", "label": "got married", "do": [ {"op":"set","stat":"married","expr":"1"}, {"op":"add","stat":"bonds","expr":"0.15"}, {"op":"spawn","stat":"spouse","expr":"partner"} ] },
    { "on": "person", "when": "gt(age,29)*gt(married,0.5)*lt(kids,0.5)", "label": "had a first child", "do": [ {"op":"set","stat":"kids","expr":"1"}, {"op":"set","stat":"kids_home","expr":"1"}, {"op":"add","stat":"bonds","expr":"0.05"}, {"op":"spawn","stat":"child","expr":"kid"} ] },
    { "on": "person", "when": "gt(age,32)*gt(kids,0.5)*lt(kids,1.5)", "label": "had a second child", "do": [ {"op":"set","stat":"kids","expr":"2"}, {"op":"set","stat":"kids_home","expr":"2"}, {"op":"spawn","stat":"child","expr":"kid"} ] },
    { "on": "person", "when": "gt(career,0.6)*gt(age,34)*eq(has_promo,0)", "label": "earned a big promotion", "do": [ {"op":"set","stat":"has_promo","expr":"1"}, {"op":"add","stat":"wealth","expr":"0.15"}, {"op":"add","stat":"career","expr":"0.08"} ] },
    { "on": "person", "when": "gt(age,43)*lt(age,49)*chance(0.4)*eq(has_setback,0)", "label": "hit a rough patch — a layoff", "do": [ {"op":"set","stat":"has_setback","expr":"1"}, {"op":"add","stat":"career","expr":"-0.25"}, {"op":"add","stat":"contentment","expr":"-0.12"} ] },
    { "on": "person", "when": "gt(age,56)*chance(0.3)*eq(has_scare,0)", "label": "had a health scare", "do": [ {"op":"set","stat":"has_scare","expr":"1"}, {"op":"add","stat":"health","expr":"-0.22"} ] },
    { "on": "person", "when": "gt(age,53)*gt(kids,1.5)*eq(has_emptynest,0)", "label": "watched the kids move out", "do": [ {"op":"set","stat":"has_emptynest","expr":"1"}, {"op":"set","stat":"kids_home","expr":"0"}, {"op":"add","stat":"contentment","expr":"-0.05"} ] },
    { "on": "person", "when": "gt(age,64)*eq(has_retired,0)", "label": "retired", "do": [ {"op":"set","stat":"has_retired","expr":"1"}, {"op":"set","stat":"career","expr":"0.1"}, {"op":"add","stat":"contentment","expr":"0.12"} ] }
  ],

  "actions": [
    { "on": "person", "name": "wrangle the kids out the door", "score": "eq(mode,1)*eq(tod,0)*gt(kids_home,0.5)*1.3", "effects": [] },
    { "on": "person", "name": "a slow quiet morning",          "score": "eq(mode,1)*eq(tod,0)*(0.6 + 0.4*gt(age,57))", "effects": [] },

    { "on": "person", "name": "buried at work",                "score": "eq(mode,1)*eq(tod,1)*career*health*1.3", "effects": [] },
    { "on": "person", "name": "job-hunting, anxious",          "score": "eq(mode,1)*eq(tod,1)*lt(career,0.2)*1.4", "effects": [] },
    { "on": "person", "name": "coasting toward the finish",    "score": "eq(mode,1)*eq(tod,1)*gt(age,56)*lt(career,0.5)*1.0", "effects": [] },
    { "on": "person", "name": "a slow retired afternoon",      "score": "eq(mode,1)*eq(tod,1)*lt(career,0.15)*gt(age,63)*1.5", "effects": [] },

    { "on": "person", "name": "a loud family dinner",          "score": "eq(mode,1)*eq(tod,2)*gt(kids_home,0.5)*1.2", "effects": [] },
    { "on": "person", "name": "dinner with old friends",       "score": "eq(mode,1)*eq(tod,2)*bonds*0.9", "effects": [] },
    { "on": "person", "name": "a quiet evening hobby",         "score": "eq(mode,1)*eq(tod,2)*(0.4 + 0.4*contentment)", "effects": [] },

    { "on": "person", "name": "sleeps soundly",                "score": "eq(mode,1)*eq(tod,3)*contentment*1.1", "effects": [] },
    { "on": "person", "name": "lies awake, mind racing",       "score": "eq(mode,1)*eq(tod,3)*(1-contentment)*1.0", "effects": [] }
  ],

  "generators": []
}
