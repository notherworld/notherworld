          "expr": "1"
        }
      ]
    },
    {
      "on": "angler",
      "name": "wait_out",
      "score": "gt(lure,0.25)*0.9",
      "effects": [
        {
          "op": "add",
          "stat": "patience",
          "expr": "0.03"
        },
        {
          "op": "set",
          "stat": "noise",
          "expr": "0.02"
        }
      ]
    },
    {
      "on": "fish",
      "name": "tempted",
      "score": "lure_s*affinity*(0.4 + 0.6*hunger)*(1 - fear)*gt(distance,0.25)*1.2",
      "effects": [
        {
          "op": "add",
          "stat": "distance",
          "expr": "-0.07*affinity"
        }
      ]
    },
    {
      "on": "fish",
      "name": "strike",
      "score": "lure_s*gt(hunger,0.3)*lt(distance,0.3)*lt(fear,0.5)*(0.4 + 0.6*boldness)*affinity*3.5",
      "effects": [
        {
          "op": "set",
          "stat": "wounded",
          "expr": "chance(0.35 + 0.5*affinity)"
        }
      ]
    },
    {
      "on": "fish",
      "name": "landed",
      "score": "gt(wounded,0.5)*10",
      "effects": [
        {
          "op": "despawn"
        }
      ]
    }
  ],
  "events": [
    {
      "on": "shore",
      "when": "gt(day,179.5)*lt(won,0.5)*lt(over,0.5)",
      "label": "dusk falls — time is up, empty-handed",
      "do": [
        {
          "op": "set",
          "stat": "over",
          "expr": "1"
        }
      ]
    },
    {
      "on": "fish",
      "when": "gt(fear,0.75)*lt(bolted,0.5)",
      "label": "one bolts — panic flashing through the crowd",
      "do": [
        {
          "op": "set",
          "stat": "bolted",
          "expr": "1"
        }
      ]
    },
    {
      "on": "fish",
      "when": "gt(wounded,0.5)*lt(down,0.5)",
