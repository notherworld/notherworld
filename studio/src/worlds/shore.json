{
  "_note": "GREYWATER SHORE — a fishing game composed from FIVE REUSED hunt packs + ONE new one (lure). Same clock, same wind/alarm perception commons (a cast's splash spooks fish the way a gunshot spooks deer), same individual variation (affinity = 'this fish likes the lure more'), same fear/flight, same grazing (plankton). Only the lure pack is new. This file is the marketplace thesis in miniature.",
  "rng_seed": 47,
  "seed": [
    {
      "kind": "shore",
      "name": "Greywater Shore",
      "reveal": true,
      "stats": {
        "wind": 0.3,
        "alarm": 0,
        "grass": 0.9,
        "day": 0,
        "school": 8,
        "won": 0,
        "over": 0
      }
    }
  ],
  "generators": [
    {
      "on": "shore",
      "spawn": "fish",
      "count": "8",
      "child_stats": {
        "hearing": "0.2 + 0.7*rand(1)",
        "boldness": "0.2 + 0.6*rand(2)",
        "affinity": "0.2 + 0.7*rand(7)",
        "fear": "0.15 + 0.1*rand(3)",
        "hunger": "0.3 + 0.3*rand(4)",
        "energy": "0.7 + 0.3*rand(5)",
        "distance": "0.45 + 0.45*rand(6)",
        "took": "0",
        "wounded": "0",
        "marked": "0",
        "down": "0",
        "bolted": "0"
      }
    },
    {
      "on": "shore",
      "spawn": "angler",
      "count": "1",
      "child_stats": {
        "stealth": "0.3",
        "patience": "0.4",
        "noise": "0.1",
        "shots": "0",
        "learned": "0"
      }
    }
  ],
  "rules": [
    {
      "on": "shore",
      "set": "day",
      "expr": "day + 1"
    },
    {
      "on": "shore",
      "set": "wind",
      "expr": "clamp(wind + 0.1*chance(0.5) - 0.1*chance(0.5), 0.05, 1)"
    },
    {
      "on": "shore",
      "set": "alarm",
      "expr": "clamp(alarm*0.82 + 0.55*noise_up*(0.4 + 0.6*wind), 0, 1)"
    },
    {
      "on": "angler",
      "set": "noise",
      "expr": "clamp(noise*0.65, 0, 1)"
    },
    {
      "on": "shore",
      "set": "grass",
      "expr": "clamp(grass + 0.03*(1 - grass) - 0.06*graze_draw, 0.05, 1)"
    },
    {
      "on": "fish",
      "set": "hunger",
      "expr": "clamp(hunger + 0.02, 0, 1)"
    },
    {
      "on": "fish",
      "set": "fear",
      "expr": "clamp(fear*0.88 + 0.9*alarm_s*hearing*(0.4 + 0.6*wind_s), 0, 1)"
    },
    {
      "on": "fish",
      "set": "distance",
      "expr": "clamp(distance, 0.05, 1)"
    },
    {
      "on": "shore",
      "set": "school",
      "expr": "child_count() - 1"
    },
    {
      "on": "angler",
      "set": "lure",
      "expr": "clamp(lure*0.9, 0, 1)"
    }
  ],
  "rollups": [
    {
      "parent": "shore",
      "child_stat": "noise",
      "parent_stat": "noise_up",
      "reduce": "max"
    },
    {
      "parent": "shore",
      "child_stat": "took",
      "parent_stat": "graze_draw",
      "reduce": "sum",
      "drain": true
    },
    {
      "parent": "shore",
      "child_stat": "lure",
      "parent_stat": "lure_up",
      "reduce": "max"
    }
  ],
  "broadcasts": [
    {
      "parent_stat": "over",
      "child_stat": "over_s",
      "gain": 1
    },
    {
      "parent_stat": "alarm",
      "child_stat": "alarm_s",
      "gain": 1
    },
    {
      "parent_stat": "wind",
      "child_stat": "wind_s",
      "gain": 1
    },
    {
      "parent_stat": "grass",
      "child_stat": "grass_s",
      "gain": 1
    },
    {
      "parent_stat": "lure_up",
      "child_stat": "lure_s",
      "gain": 1
    }
  ],
  "actions": [
    {
      "on": "fish",
