      "effects": [
        {
          "op": "add",
          "stat": "hunger",
          "expr": "-0.12"
        },
        {
          "op": "set",
          "stat": "took",
          "expr": "0.1"
        },
        {
          "op": "add",
          "stat": "distance",
          "expr": "-0.04*boldness"
        },
        {
          "op": "add",
          "stat": "energy",
          "expr": "0.02"
        }
      ]
    },
    {
      "on": "fish",
      "name": "flee",
      "score": "gt(fear,0.6)*gt(energy,0.1)*1.6",
      "effects": [
        {
          "op": "add",
          "stat": "distance",
          "expr": "0.18"
        },
        {
          "op": "add",
          "stat": "energy",
          "expr": "-0.1"
        },
        {
          "op": "add",
          "stat": "fear",
          "expr": "-0.14"
        }
      ]
    },
    {
      "on": "fish",
      "name": "rest",
      "score": "lt(energy,0.35)*0.9",
      "effects": [
        {
          "op": "add",
          "stat": "energy",
          "expr": "0.12"
        }
      ]
    },
    {
      "on": "fish",
      "name": "drift",
      "score": "0.25 + 0.15*chance(0.5)",
      "effects": [
        {
          "op": "add",
          "stat": "distance",
          "expr": "0.12*chance(0.5) - 0.06"
        }
      ]
    },
    {
      "on": "angler",
      "name": "cast",
      "score": "lt(lure,0.3)*lt(over_s,0.5)*(0.6 + 0.4*chance(0.5))",
      "effects": [
        {
          "op": "set",
          "stat": "lure",
          "expr": "1"
        },
        {
          "op": "add",
          "stat": "noise",
          "expr": "0.35"
        },
        {
          "op": "add",
